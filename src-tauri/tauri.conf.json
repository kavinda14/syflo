{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syflo",
  "version": "0.1.0",
  "identifier": "app.syflo",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && bash ../scripts/sync-tauri-resources.sh"
  },
  "app": {
    "windows": [
      {
        "title": "Syflo",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/node/node",
      "resources/backend/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
