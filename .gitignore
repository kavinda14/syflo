# Dependencies
node_modules/

# Build output
dist/
build/

# Environment / secrets
.env
.env.local
.env.*.local

# Local database
*.db
*.sqlite
*.sqlite3

# User-uploaded message attachments
uploads/

# Whisper models (480 MB) — downloaded by scripts/setup-whisper.sh
models/

# Logs
logs/
*.log
npm-debug.log*

# IDE / OS
.DS_Store
.vscode/
.idea/

# Test coverage
coverage/

# Tauri (Rust) build artifacts — `target/` is multi-GB and platform-specific.
# The lockfile + source under src-tauri/ stays in the repo.
src-tauri/target/
src-tauri/gen/

# Tauri bundled resources — synced from backend/ before each build.
# Source of truth lives in backend/. Re-create with `npm run sync-backend`.
src-tauri/resources/backend/
src-tauri/resources/node/
